// Prisma schema proposal (control plane + tenant runtime tables)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspaces  Workspace[]
  users       User[]
}

model Workspace {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       WorkspaceUser[]

  @@index([tenantId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  AGENT
  MARKETING_MANAGER
  ANALYST
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  email         String
  fullName      String
  passwordHash  String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaces    WorkspaceUser[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model WorkspaceUser {
  id           String        @id @default(cuid())
  workspaceId  String
  userId       String
  role         WorkspaceRole
  createdAt    DateTime      @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  workspaceId   String?
  actorUserId   String?
  action        String
  entityType    String
  entityId      String?
  metadataJson  String
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([workspaceId, createdAt])
}

model BillingSubscription {
  id                      String   @id @default(cuid())
  tenantId                String   @unique
  stripeCustomerId        String
  stripeSubscriptionId    String?
  planCode                String
  status                  String
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([tenantId])
}

model BillingUsage {
  id             String   @id @default(cuid())
  tenantId       String
  metricCode     String
  periodKey      String
  value          Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, metricCode, periodKey])
  @@index([tenantId, periodKey])
}
