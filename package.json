{
  "name": "whatsapp-bot-marketing-auto",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean:web": "node -e \"try{require('fs').rmSync('apps/web/.next',{recursive:true,force:true});console.log('cleaned apps/web/.next')}catch(e){console.error(e);process.exit(1)}\"",
    "dev:api": "npm run dev --workspace @app/api",
    "dev:web": "npm run dev --workspace @app/web",
    "dev:web:clean": "npm run clean:web && npm run dev:web",
    "typecheck": "npm run --workspaces typecheck",
    "lint": "npm run --workspaces lint",
    "dev": "npm run --workspaces dev",
    "build": "npm run --workspaces build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
